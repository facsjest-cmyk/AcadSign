<Window x:Class="SimpleLoginTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AcadSign - Connexion" Height="400" Width="400"
        Background="#1E1E1E">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
        <TextBlock Text="AcadSign Login" FontSize="24" Foreground="White" Margin="0,0,0,30" HorizontalAlignment="Center"/>
        
        <TextBlock Text="Username:" Foreground="White" Margin="0,0,0,5"/>
        <TextBox x:Name="UsernameBox" Padding="5" Margin="0,0,0,15"/>
        
        <TextBlock Text="Password:" Foreground="White" Margin="0,0,0,5"/>
        <PasswordBox x:Name="PasswordBox" Padding="5" Margin="0,0,0,20"/>
        
        <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,10" Visibility="Collapsed"/>
        
        <Button x:Name="LoginBtn" Content="Se connecter" Padding="0,10" Click="LoginBtn_Click"/>
        
        <TextBlock x:Name="StatusText" Foreground="LightGray" Margin="0,15,0,0" HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
