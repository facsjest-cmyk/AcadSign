<Window x:Class="AcadSign.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AcadSign - Connexion" 
        Height="650" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    
    <Border Background="{StaticResource BgBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="12"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid>
            <ContentControl x:Name="LoginControl"/>
            
            <Button Content="✕" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top"
                    Width="40" Height="40"
                    Foreground="White"
                    FontSize="16"
                    Cursor="Hand"
                    Click="CloseButton_Click"
                    Margin="0,8,8,0"
                    Panel.ZIndex="1">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#25FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>