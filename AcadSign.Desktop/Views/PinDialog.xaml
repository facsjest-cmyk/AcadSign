<Window x:Class="AcadSign.Desktop.Views.PinDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PIN Dongle"
        Width="420"
        Height="220"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Saisissez le PIN du dongle"
                   Foreground="#CCCCCC"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,15"/>

        <PasswordBox x:Name="PinBox"
                     Grid.Row="1"
                     Height="34"
                     Padding="10,6"
                     Background="#252526"
                     Foreground="#CCCCCC"
                     BorderBrush="#3E3E42"/>

        <TextBlock Grid.Row="2"
                   Text="Le PIN n'est pas stocké."
                   Foreground="#858585"
                   Margin="0,10,0,0"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Annuler" Width="110" Height="34" Margin="0,0,10,0" Click="Cancel_Click"
                    Background="#3E3E42" Foreground="#CCCCCC" BorderBrush="#3E3E42"/>
            <Button Content="Valider" Width="110" Height="34" Click="Ok_Click"
                    Background="#007ACC" Foreground="White" BorderBrush="#007ACC"/>
        </StackPanel>
    </Grid>
</Window>
