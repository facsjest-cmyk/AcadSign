<Window x:Class="AcadSign.Desktop.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:AcadSign.Desktop.Converters"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="AcadSign Desktop"
        Width="1380"
        Height="820"
        MinWidth="1100"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
        <conv:StatusIconToBrushConverter x:Key="StatusIconToBrushConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
        <conv:InverseNullToVisibilityConverter x:Key="InvNullVis"/>
        <conv:StatusToColorConverter x:Key="StatusColor"/>
        <conv:StatusToBackgroundConverter x:Key="StatusBg"/>
        <conv:StatusToLabelConverter x:Key="StatusLabel"/>
        <conv:StatusToBorderBrushConverter x:Key="StatusBorder"/>
        <conv:ViewModeToLabelConverter x:Key="ViewModeLabel"/>
        <conv:DocTypeToShortLabelConverter x:Key="DocTypeShort"/>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Margin="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#020817" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="18" Height="18" CornerRadius="4" Background="{StaticResource AccentGradient}" Margin="0,0,8,0">
                            <TextBlock Text="✍" Foreground="White" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="AcadSign Desktop • v2.1.0 — Université Hassan II" Foreground="{StaticResource SubBrush}" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MinimizeButton" Style="{StaticResource TitleBarButtonStyle}" Background="#F5C542" Margin="0,0,8,0" Click="MinimizeButton_Click"/>
                        <Button x:Name="MaximizeButton" Style="{StaticResource TitleBarButtonStyle}" Background="#34D399" Margin="0,0,8,0" Click="MaximizeButton_Click"/>
                        <Button x:Name="CloseButton" Style="{StaticResource TitleBarButtonStyle}" Background="#F87171" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Barre supérieure -->
            <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="8,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource ToolbarButtonStyle}" Content="⟳ Charger&#x0a;API" Margin="0,0,6,0" Command="{Binding LoadDocumentsUiCommand}"/>
                        <Button Style="{StaticResource ToolbarButtonStyle}" Content="🧾 Générer&#x0a;attestations" Margin="0,0,6,0" Command="{Binding GenerateAttestationsFromSisCommand}"/>
                        <Button Style="{StaticResource ToolbarButtonStyle}" Content="◉ Avant&#x0a;signature" Margin="0,0,6,0" Command="{Binding OpenBeforeSignatureCommand}"/>
                        <Button Style="{StaticResource ToolbarButtonStyle}" Content="✎ Après&#x0a;signature" Margin="0,0,10,0" Command="{Binding OpenAfterSignatureCommand}"/>
                        <Button Style="{StaticResource ToolbarButtonGreenStyle}" Content="✍ Signer&#x0a;document" Margin="0,0,8,0" Command="{Binding SignDocumentCommand}" CommandParameter="{Binding SelectedDocument}"/>
                        <Button Style="{StaticResource ToolbarButtonGreenStyle}" Content="⚡ Signature&#x0a;par lot ( 0 )" Margin="0,0,8,0" Command="{Binding StartBatchSigningCommand}"/>
                        <Button Style="{StaticResource ToolbarButtonStyle}" Content="✉ Envoyer&#x0a;par email" Margin="0,0,6,0" Command="{Binding SendByEmailCommand}"/>
                        <Button Style="{StaticResource ToolbarButtonStyle}" Content="📁 Exporter&#x0a;attestations" Margin="0,0,6,0" Command="{Binding ExportGeneratedAttestationsCommand}"/>
                        <Button Style="{StaticResource ToolbarButtonDangerStyle}" Content="🗑 Purger&#x0a;signés" Margin="0,0,10,0" Command="{Binding PurgeSignedCommand}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Foreground="{StaticResource GreenBrush}" FontSize="12" MinWidth="82" TextAlignment="Center" Margin="0,0,16,0" Text="e-Sign&#x0a;API:&#x0a;Connecté"/>
                        <TextBlock Foreground="{StaticResource GreenBrush}" FontSize="12" MinWidth="82" TextAlignment="Center" Margin="0,0,16,0" Text="S3:&#x0a;En&#x0a;ligne"/>
                        <TextBlock Foreground="{StaticResource AmberBrush}" FontSize="12" MinWidth="82" TextAlignment="Center" Margin="0,0,16,0" Text="SIS&#x0a;API:&#x0a;Prêt"/>
                        <Button Style="{StaticResource ToolbarButtonDangerStyle}" Content="🚪 Déconnexion" Command="{Binding LogoutCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="290"/>
                </Grid.ColumnDefinitions>

                <!-- Panneau gauche - Liste des demandes -->
                <Border Grid.Column="0" Background="#0D1728" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="12,12,12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DEMANDES" Style="{StaticResource SectionLabelStyle}" Margin="0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border Width="22" Height="18" Background="{StaticResource AmberBrush}" CornerRadius="9" Margin="0,0,6,0">
                                    <TextBlock Text="{Binding PendingCount}" Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Width="22" Height="18" Background="{StaticResource GreenBrush}" CornerRadius="9">
                                    <TextBlock Text="{Binding SignedCount}" Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,10,10">
                            <RadioButton Content="Tous" Style="{StaticResource FilterChipStyle}" Margin="0,0,8,0" IsChecked="True" Command="{Binding SetFilterCommand}" CommandParameter="all"/>
                            <RadioButton Content="En attente" Style="{StaticResource FilterChipStyle}" Margin="0,0,8,0" Command="{Binding SetFilterCommand}" CommandParameter="pending"/>
                            <RadioButton Content="Signés" Style="{StaticResource FilterChipStyle}" Margin="0,0,8,0" Command="{Binding SetFilterCommand}" CommandParameter="signed"/>
                            <RadioButton Content="Erreur" Style="{StaticResource FilterChipStyle}" Command="{Binding SetFilterCommand}" CommandParameter="error"/>
                        </StackPanel>

                        <Grid Grid.Row="2" Margin="10,0,10,12">
                            <TextBox x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkInputStyle}" Height="34" Foreground="White" CaretBrush="White"/>
                            <TextBlock Text="⌕   Rechercher..." Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False" Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource StringNotEmptyToVisibilityConverter}, ConverterParameter=invert}"/>
                        </Grid>

                        <ListBox Grid.Row="3" ItemsSource="{Binding FilteredDocuments}" SelectedItem="{Binding SelectedDocument}" Style="{StaticResource DocListBoxStyle}" Margin="0,0,2,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="{Binding Status, Converter={StaticResource StatusColor}}" CornerRadius="3" Margin="0,2,10,2"/>

                                        <CheckBox Grid.Column="1" IsChecked="{Binding IsSelected}" VerticalAlignment="Top" Margin="0,2,12,0"/>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding StudentName}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding StudentId, FallbackValue=E-2024-001}" Foreground="#64748B" FontFamily="Consolas" FontSize="11"/>
                                                <Border Background="#1E293B" CornerRadius="5" Padding="7,2" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding DocumentType, Converter={StaticResource DocTypeShort}}" Foreground="#6366F1" FontSize="10" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DocumentType}" Foreground="#64748B" FontSize="11" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <Grid Grid.Column="3" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <Ellipse x:Name="PendingDot" Width="8" Height="8" Fill="{Binding Status, Converter={StaticResource StatusColor}}"/>
                                            <Border x:Name="SignedCheck" Width="18" Height="18" Background="#10B981" CornerRadius="9" Visibility="Collapsed">
                                                <TextBlock Text="✓" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="SIGNED">
                                            <Setter TargetName="SignedCheck" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="PendingDot" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="EMAIL_SENT">
                                            <Setter TargetName="SignedCheck" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="PendingDot" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="4" Margin="12,8,12,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Foreground="{StaticResource SubBrush}" FontSize="11">
                                <Run Text="☐ "/><Run Text="{Binding SelectedCount, Mode=OneWay}"/><Run Text=" sélectionné(s)"/>
                            </TextBlock>
                            <Button Grid.Column="1" Content="Tout sélectionner" Command="{Binding SelectAllCommand}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource AccentBlueBrush}" FontSize="11" Padding="0" Cursor="Hand"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Panneau central - Prévisualisation du document -->
                <Border Grid.Column="1" Background="#07101F">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#091221" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid Margin="12,6,12,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Page" Foreground="{StaticResource SubBrush}" FontSize="12" Margin="0,0,8,0"/>
                                    <TextBlock Text="1 / 1" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" FontSize="12" Margin="0,0,10,0"/>
                                    <Button Content="◀" Style="{StaticResource PdfToolButtonStyle}" Margin="0,0,6,0"/>
                                    <Button Content="▶" Style="{StaticResource PdfToolButtonStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Content="－" Style="{StaticResource PdfToolButtonStyle}" Margin="0,0,6,0"/>
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,6" Margin="0,0,6,0">
                                        <TextBlock Text="100%" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="12"/>
                                    </Border>
                                    <Button Content="＋" Style="{StaticResource PdfToolButtonStyle}" Margin="0,0,12,0"/>
                                    <Button Content="↻" Style="{StaticResource PdfToolButtonStyle}" Margin="0,0,6,0"/>
                                    <Button Content="⬇" Style="{StaticResource PdfToolButtonStyle}" Margin="0,0,6,0"/>
                                    <Button Content="🖨" Style="{StaticResource PdfToolButtonStyle}"/>
                                </StackPanel>

                                <Button Grid.Column="2" Content="Avant" Style="{StaticResource ToolbarButtonStyle}" Background="#0EA5E920" Foreground="{StaticResource AccentBlueBrush}" BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1" Command="{Binding OpenBeforeSignatureCommand}"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="0">
                            <Border Margin="0,0,0,0" Background="#D6D3D1" BorderBrush="#1F2937" BorderThickness="1,0,1,0">
                                <Grid>
                                    <wv2:WebView2 Source="{Binding PreviewUri}" DefaultBackgroundColor="White" Margin="0"/>

                                    <Border Background="#AA020617" Visibility="{Binding IsPreviewLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <ProgressBar Style="{StaticResource SignProgressBarStyle}" Width="180" IsIndeterminate="True"/>
                                            <TextBlock Text="{Binding PreviewStatusText}" Foreground="White" FontSize="13" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#AA020617" Visibility="{Binding PreviewUri, Converter={StaticResource InvNullVis}}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="Aucun aperçu chargé" Foreground="White" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Clique sur Charger API puis sélectionne un document" Foreground="{StaticResource SubBrush}" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Panneau droit - Informations -->
                <Border Grid.Column="2" Background="#0B1527" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource PanelSectionStyle}">
                                <StackPanel>
                                    <TextBlock Text="ÉTUDIANT" Style="{StaticResource SectionLabelStyle}"/>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Nom" Style="{StaticResource InfoKeyStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedDocument.StudentName, FallbackValue=—}" Style="{StaticResource InfoValStyle}" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="CIN" Style="{StaticResource InfoKeyStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedDocument.Cin, FallbackValue=BE123456}" Style="{StaticResource InfoValStyle}" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="N° Apogée" Style="{StaticResource InfoKeyStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedDocument.StudentId, FallbackValue=E-2024-001}" Style="{StaticResource InfoValStyle}" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Filière" Style="{StaticResource InfoKeyStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedDocument.Program, FallbackValue=Génie Informatique}" Style="{StaticResource InfoValStyle}" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Niveau" Style="{StaticResource InfoKeyStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedDocument.Level, FallbackValue=3ème année}" Style="{StaticResource InfoValStyle}" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelSectionStyle}">
                                <StackPanel>
                                    <TextBlock Text="DOCUMENT" Style="{StaticResource SectionLabelStyle}"/>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Type" Style="{StaticResource InfoKeyStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedDocument.DocumentType, FallbackValue=Attestation de Scolarité}" Style="{StaticResource InfoValStyle}" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Statut" Style="{StaticResource InfoKeyStyle}"/>
                                        <Border Grid.Column="1" Style="{StaticResource StatusPillStyle}" Background="{Binding SelectedDocument.Status, Converter={StaticResource StatusBg}}" BorderBrush="{Binding SelectedDocument.Status, Converter={StaticResource StatusBorder}}" BorderThickness="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding SelectedDocument.Status, Converter={StaticResource StatusLabel}}" Foreground="{Binding SelectedDocument.Status, Converter={StaticResource StatusColor}}" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Réf." Style="{StaticResource InfoKeyStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedDocument.Reference, FallbackValue=REF-2024-001}" Style="{StaticResource InfoValStyle}" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Généré" Style="{StaticResource InfoKeyStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedDocument.CreatedAt, StringFormat=dd/MM/yyyy, FallbackValue=03/03/2025}" Style="{StaticResource InfoValStyle}" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Padding="14,12">
                                <StackPanel>
                                    <TextBlock Text="SIGNATURE ÉLECTRONIQUE" Style="{StaticResource SectionLabelStyle}"/>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Certificat" Style="{StaticResource InfoKeyStyle}"/>
                                        <TextBlock Grid.Column="1" Text="UH2-ESIGN-2024" Foreground="{StaticResource GreenBrush}" FontFamily="Consolas" FontSize="12" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Standard" Style="{StaticResource InfoKeyStyle}"/>
                                        <TextBlock Grid.Column="1" Text="PAdES-B-LT" Style="{StaticResource InfoValStyle}" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Expire" Style="{StaticResource InfoKeyStyle}"/>
                                        <TextBlock Grid.Column="1" Text="31/12/2025" Style="{StaticResource InfoValStyle}" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Border Background="#07101F" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,18">
                                        <StackPanel>
                                            <UniformGrid Rows="1" Columns="6" HorizontalAlignment="Center">
                                                <Ellipse Width="5" Height="5" Fill="#9CA3AF" Margin="8,0"/>
                                                <Ellipse Width="5" Height="5" Fill="#9CA3AF" Margin="8,0"/>
                                                <Ellipse Width="5" Height="5" Fill="#9CA3AF" Margin="8,0"/>
                                                <Ellipse Width="5" Height="5" Fill="#9CA3AF" Margin="8,0"/>
                                                <Ellipse Width="5" Height="5" Fill="#9CA3AF" Margin="8,0"/>
                                                <Ellipse Width="5" Height="5" Fill="#9CA3AF" Margin="8,0"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Barre de statut -->
            <Border Grid.Row="3" Background="#030712" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource GreenBrush}" Margin="0,0,6,0"/>
                        <TextBlock Text="Connecté — Barid Al-Maghrib e-Sign" Foreground="{StaticResource SubBrush}" FontSize="11" Margin="0,0,18,0"/>
                        <TextBlock Text="📄" Foreground="{StaticResource SubBrush}" FontSize="11" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding TotalCount}" Foreground="{StaticResource SubBrush}" FontSize="11" Margin="0,0,14,0"/>
                        <TextBlock Text="✅" Foreground="{StaticResource GreenBrush}" FontSize="11" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding SignedCount}" Foreground="{StaticResource SubBrush}" FontSize="11" Margin="0,0,14,0"/>
                        <TextBlock Text="⏳" Foreground="{StaticResource AmberBrush}" FontSize="11" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding PendingCount}" Foreground="{StaticResource SubBrush}" FontSize="11" Margin="0,0,18,0"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="{Binding CurrentTime}" Foreground="{StaticResource SubBrush}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
