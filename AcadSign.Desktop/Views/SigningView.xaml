<Window x:Class="AcadSign.Desktop.Views.SigningView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AcadSign - Signature de Document" 
        Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#2196F3" Padding="20">
            <StackPanel>
            <TextBlock Text="Signature en cours" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
        
        <StackPanel Grid.Row="1" 
                    Margin="40"
                    VerticalAlignment="Center">
            
            <TextBlock Text="{Binding DocumentName}" 
                       FontSize="18" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>
            
            <TextBlock Text="{Binding StatusMessage}" 
                       FontSize="14" 
                       Foreground="#666"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>
            
            <ProgressBar Value="{Binding Progress}"
                         Height="20"
                         Minimum="0"
                         Maximum="100"
                         Margin="0,0,0,20"/>
            
            <TextBlock Text="{Binding ProgressText}" 
                       FontSize="12" 
                       Foreground="#999"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
            
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">
                <Button Content="Annuler"
                        Command="{Binding CancelCommand}"
                        Width="120"
                        Height="35"
                        Margin="5"
                        Background="#F44336"
                        Foreground="White"
                        BorderThickness="0"
                        Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="Retour"
                        Command="{Binding GoBackCommand}"
                        Width="120"
                        Height="35"
                        Margin="5"
                        Background="#2196F3"
                        Foreground="White"
                        BorderThickness="0"
                        Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </StackPanel>
        
        <TextBlock Grid.Row="2" 
                   Text="Veuillez ne pas fermer cette fenêtre pendant la signature"
                   FontSize="11"
                   Foreground="#999"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>
    </Grid>
</Window>
