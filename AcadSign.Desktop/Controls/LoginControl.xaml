<UserControl x:Class="AcadSign.Desktop.Controls.LoginControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- En-tête avec design moderne -->
        <Border Grid.Row="0" Background="{StaticResource AccentBlueBrush}" Padding="30,42">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="🎓" FontSize="42" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                <TextBlock Text="AcadSign Desktop" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Université Hassan II - Casablanca" 
                           FontSize="14" 
                           Foreground="#DCEBFF"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Formulaire de connexion avec ScrollViewer -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="{StaticResource BgBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320" Margin="40,30">
                <TextBlock Text="Connexion" 
                           FontSize="24" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,30"/>
            
                <!-- Nom d'utilisateur -->
                <TextBlock Text="Nom d'utilisateur" 
                           Foreground="{StaticResource TextBrush}" 
                           FontSize="13"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="UsernameTextBox"
                         Background="{StaticResource CardBrush}"
                         Style="{StaticResource DarkInputStyle}"
                         Margin="0,0,0,20"/>
            
                <!-- Mot de passe -->
                <TextBlock Text="Mot de passe" 
                           Foreground="{StaticResource TextBrush}" 
                           FontSize="13"
                           Margin="0,0,0,8"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource DarkPasswordStyle}"
                             KeyDown="PasswordBox_KeyDown"
                             Margin="0,0,0,10"/>
            
                <!-- Se souvenir de moi -->
                <CheckBox x:Name="RememberMeCheckBox"
                          Content="Se souvenir de moi"
                          Foreground="{StaticResource TextBrush}"
                          Margin="0,0,0,25"/>
            
                <!-- Message d'erreur -->
                <Border x:Name="ErrorBorder"
                        Background="#4A1F1F" 
                        BorderBrush="{StaticResource RedBrush}" 
                        BorderThickness="1"
                        Padding="12,10"
                        Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorTextBlock"
                               Foreground="#FF8C74" 
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </Border>
            
                <!-- Bouton de connexion -->
                <Button x:Name="LoginButton"
                        Content="Se connecter"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Height="66"
                        Click="LoginButton_Click"/>
            
                <!-- Indicateur de chargement -->
                <ProgressBar x:Name="LoadingIndicator"
                             IsIndeterminate="True"
                             Height="3"
                             Margin="0,15,0,0"
                             Style="{StaticResource SignProgressBarStyle}"
                             Visibility="Collapsed"/>
            
                <TextBlock x:Name="StatusTextBlock"
                           Foreground="{StaticResource MutedBrush}" 
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Pied de page -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" Padding="20,15">
            <TextBlock Text="© 2026 Université Hassan II - Casablanca" 
                       FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
