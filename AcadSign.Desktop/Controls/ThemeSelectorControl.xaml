<UserControl x:Class="AcadSign.Desktop.Controls.ThemeSelectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AcadSign.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="300">
    
    <UserControl.DataContext>
        <vm:ThemeViewModel/>
    </UserControl.DataContext>
    
    <Border Background="{StaticResource PanelBrush}" 
            BorderBrush="{StaticResource BorderBrush}" 
            BorderThickness="1" 
            CornerRadius="8" 
            Padding="12,8">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Thème:" 
                       VerticalAlignment="Center" 
                       Foreground="{StaticResource TextBrush}" 
                       FontSize="12" 
                       Margin="0,0,8,0"/>
            
            <RadioButton x:Name="LightThemeBtn" 
                         Content="☀️ Clair" 
                         IsChecked="{Binding CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light}"
                         Style="{StaticResource FilterChipStyle}"
                         Margin="0,0,4,0"/>
            
            <RadioButton x:Name="DarkThemeBtn" 
                         Content="🌙 Sombre" 
                         IsChecked="{Binding CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark}"
                         Style="{StaticResource FilterChipStyle}"
                         Margin="0,0,4,0"/>
            
            <RadioButton x:Name="EstablishmentThemeBtn" 
                         Content="🏛️ Établissement" 
                         IsChecked="{Binding CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Establishment}"
                         Style="{StaticResource FilterChipStyle}"/>
        </StackPanel>
    </Border>
</UserControl>
