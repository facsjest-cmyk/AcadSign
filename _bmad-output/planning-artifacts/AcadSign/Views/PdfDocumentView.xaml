<UserControl x:Class="AcadSign.Views.PdfDocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:AcadSign.Models"
             Width="480">

    <!--
         This UserControl renders an inline WPF representation of the document.
         In production, replace this with a PdfiumViewer or WebBrowser control
         rendering actual PDF bytes via IPdfViewerService.
    -->

    <Border Background="White" Width="480" MinHeight="680"
            Padding="44,40">
        <StackPanel DataContext="{Binding}">

            <!-- Institution header -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Border Grid.Column="0" Width="58" Height="58" CornerRadius="6"
                        Margin="0,0,14,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E3A5F" Offset="0"/>
                            <GradientStop Color="#2563EB" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🎓" FontSize="26"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Institution name -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="UNIVERSITÉ HASSAN II DE CASABLANCA"
                               FontSize="11" FontWeight="Bold" Foreground="#1E3A5F"
                               LetterSpacing="0.5"/>
                    <TextBlock Text="جامعة الحسن الثاني بالدار البيضاء"
                               FontSize="10" Foreground="#64748B" Margin="0,2,0,0"/>
                    <TextBlock Text="Service de Scolarité — الشؤون الطلابية"
                               FontSize="9" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Reference -->
                <StackPanel Grid.Column="2" VerticalAlignment="Top">
                    <TextBlock Text="{Binding Reference, FallbackValue='REF-2024-XXX'}"
                               FontFamily="Consolas" FontSize="10" Foreground="#94A3B8"
                               TextAlignment="Right"/>
                    <TextBlock Text="{Binding DisplayDate}"
                               FontSize="10" Foreground="#94A3B8"
                               TextAlignment="Right" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Gradient divider -->
            <Border Height="3" CornerRadius="2" Margin="0,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#1E3A5F" Offset="0"/>
                        <GradientStop Color="#2563EB" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Document title -->
            <TextBlock Text="{Binding DisplayType}"
                       FontSize="15" FontWeight="Bold" Foreground="#1E3A5F"
                       HorizontalAlignment="Center" Margin="0,0,0,20"
                       LetterSpacing="1"/>

            <!-- Body text -->
            <TextBlock TextWrapping="Wrap" Foreground="#334155" FontSize="12"
                       LineHeight="22" Margin="0,0,0,10">
                Le soussigné, Chef du Service de Scolarité de l'Université Hassan II
                de Casablanca, atteste que :
            </TextBlock>

            <!-- Student data block -->
            <Border Background="#F8FAFC"
                    BorderBrush="#6366F1" BorderThickness="3,0,0,0"
                    Padding="14,12" Margin="0,8,0,14" CornerRadius="0,6,6,0">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Nom et prénom :" FontWeight="Bold"
                                   FontSize="11" Foreground="#1E3A5F"/>
                        <TextBlock Grid.Column="1" Text="{Binding Student.FullName}"
                                   FontSize="11" Foreground="#334155"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="CIN :" FontWeight="Bold"
                                   FontSize="11" Foreground="#1E3A5F"/>
                        <TextBlock Grid.Column="1" Text="{Binding Student.Cin}"
                                   FontFamily="Consolas" FontSize="11" Foreground="#334155"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="N° Apogée :" FontWeight="Bold"
                                   FontSize="11" Foreground="#1E3A5F"/>
                        <TextBlock Grid.Column="1" Text="{Binding Student.Id}"
                                   FontFamily="Consolas" FontSize="11" Foreground="#334155"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Filière :" FontWeight="Bold"
                                   FontSize="11" Foreground="#1E3A5F"/>
                        <TextBlock Grid.Column="1" Text="{Binding Student.Program}"
                                   FontSize="11" Foreground="#334155"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Niveau :" FontWeight="Bold"
                                   FontSize="11" Foreground="#1E3A5F"/>
                        <TextBlock Grid.Column="1" Text="{Binding Student.Level}"
                                   FontSize="11" Foreground="#334155"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Année univ. :" FontWeight="Bold"
                                   FontSize="11" Foreground="#1E3A5F"/>
                        <TextBlock Grid.Column="1" Text="{Binding Student.AcademicYear}"
                                   FontSize="11" Foreground="#334155"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Body continued -->
            <TextBlock TextWrapping="Wrap" Foreground="#334155" FontSize="12"
                       LineHeight="22" Margin="0,0,0,6">
                est régulièrement inscrit(e) et suit ses études au sein de notre
                établissement durant l'année universitaire en cours.
            </TextBlock>
            <TextBlock TextWrapping="Wrap" Foreground="#334155" FontSize="12"
                       LineHeight="22" Margin="0,0,0,30">
                En foi de quoi, la présente attestation lui est délivrée pour
                servir et valoir ce que de droit.
            </TextBlock>

            <!-- Signature block -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Signature zone -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Le Chef de Scolarité" FontSize="10"
                               Foreground="#64748B" Margin="0,0,0,8"/>

                    <!-- Unsigned state -->
                    <Border Width="150" Height="60" CornerRadius="4"
                            BorderBrush="#CBD5E1" BorderThickness="1"
                            BorderBrush2="{x:Null}"
                            Visibility="{Binding DataContext.IsSignedView,
                                         RelativeSource={RelativeSource AncestorType=Window},
                                         Converter={StaticResource InvBoolVis}}">
                        <TextBlock Text="Signature" FontSize="11" Foreground="#94A3B8"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Signed state -->
                    <Border Width="150" Height="60" CornerRadius="4"
                            BorderBrush="#10B981" BorderThickness="1"
                            Background="#F0FDF4"
                            Visibility="{Binding DataContext.IsSignedView,
                                         RelativeSource={RelativeSource AncestorType=Window},
                                         Converter={StaticResource BoolVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="✓ Signé numériquement" FontSize="10"
                                       Foreground="#10B981" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="PAdES-B-LT" FontSize="9"
                                       Foreground="#64748B" FontFamily="Consolas"
                                       HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            <TextBlock Text="Barid Al-Maghrib e-Sign" FontSize="8"
                                       Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- eIDAS badge (after signing) -->
                    <TextBlock Margin="0,5,0,0" FontSize="9"
                               Foreground="#10B981" FontFamily="Consolas"
                               Visibility="{Binding DataContext.IsSignedView,
                                            RelativeSource={RelativeSource AncestorType=Window},
                                            Converter={StaticResource BoolVis}}"
                               Text="✓ Signature qualifiée eIDAS"/>
                </StackPanel>

                <!-- Center: QR code mock -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center"
                            VerticalAlignment="Bottom">
                    <Border Width="50" Height="50" Background="#1E3A5F"
                            CornerRadius="3">
                        <!-- Real QR: use ZXing.Net or QRCoder library -->
                        <TextBlock Text="⬛" FontSize="30"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Vérifier" FontSize="9" Foreground="#94A3B8"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Right: Date and place -->
                <StackPanel Grid.Column="2" VerticalAlignment="Bottom"
                            HorizontalAlignment="Right">
                    <TextBlock FontSize="10" Foreground="#94A3B8" TextAlignment="Right">
                        <Run Text="Casablanca, le "/>
                        <Run Text="{Binding DisplayDate}"/>
                    </TextBlock>
                    <!-- Cert details after signing -->
                    <StackPanel Margin="0,8,0,0"
                                Visibility="{Binding DataContext.IsSignedView,
                                             RelativeSource={RelativeSource AncestorType=Window},
                                             Converter={StaticResource BoolVis}}">
                        <TextBlock FontFamily="Consolas" FontSize="8" Foreground="#10B981"
                                   TextAlignment="Right"
                                   Text="{Binding CertificateSerial, FallbackValue='CERT: UH2-SIGN-2024'}"/>
                        <TextBlock FontFamily="Consolas" FontSize="8" Foreground="#94A3B8"
                                   TextAlignment="Right"
                                   Text="{Binding SignedAt, StringFormat='TS: {0:yyyy-MM-dd}',
                                          FallbackValue='TS: 2024-03-04'}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
